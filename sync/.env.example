# RetailCRM
RETAILCRM_URL=https://yourshop.retailcrm.ru
RETAILCRM_API_KEY=your_retailcrm_api_key

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Настройки синхронизации
SYNC_INTERVAL_MS=300000      # 5 минут (для --watch режима)
UPLOAD_BATCH_DELAY_MS=500    # Задержка между запросами (rate limit)
ORDERS_LIMIT=100             # Кол-во заказов за один запрос к RetailCRM

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
NOTIFY_THRESHOLD_SUM=50000

# Webhook сервер (вариант 1, опционально)
WEBHOOK_PORT=3001
WEBHOOK_SECRET=my_secret_token
